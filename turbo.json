{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    
    "api-service": {
        "dependsOn": ["^build", "db:generate"],
        "env": [],
        "cache": false
    },
    "worker-email": {
        "dependsOn": ["^build"],
        "env": [],
        "cache": false
    },
    "worker-sms": {
        "dependsOn": ["^build"],
        "env": [],
        "cache": false
    },
    "worker-push": {
        "dependsOn": ["^build"],
        "env": [],
        "cache": false
    },
        "db:generate": {
      "cache": false
    },

    "db:migrate": {
      "cache": false
    },

    "db:studio": {
      "cache": false
    },

    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["db:generate"]
    }
  }
}
